# Copy this file to ".env" (in the backend/ folder) and fill in your values.

# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use.
GEMINI_MODEL=gemini-2.5-flash

# ElevenLabs voice engine. Keep the API key backend-only.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Port the Express backend listens on.
PORT=3001

# Supabase project settings. The service role key must stay backend-only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
